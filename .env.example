# Supabase — https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Server-only — never expose to the browser
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Database (Project Settings → Database) — required for npm run setup:stage*
SUPABASE_DB_PASSWORD=your-database-password

# Optional — Supabase pooler (defaults: aws-0-eu-west-1.pooler.supabase.com:5432)
# SUPABASE_DB_POOLER_HOST=aws-0-eu-west-1.pooler.supabase.com
# SUPABASE_DB_POOLER_PORT=5432
# SUPABASE_PROJECT_REF=your-project-ref

# Optional — personal access token for auth URL auto-config
# SUPABASE_ACCESS_TOKEN=

# Production — set to false to disable open registration
# ALLOW_PUBLIC_REGISTRATION=false

# OpenAI — Club AI Assistant (server-only, never commit real keys)
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
