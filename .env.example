# Supabase — https://supabase.com/dashboard/project/pwkqnwqvrdiaycveacxa/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Server-only — never expose to the browser
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Database password (Project Settings → Database) — required for npm run setup:stage1
SUPABASE_DB_PASSWORD=your-database-password

# Optional — personal access token for auth URL auto-config
# SUPABASE_ACCESS_TOKEN=
